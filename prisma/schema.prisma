generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model StreamerProfile {
  userLogin   String   @id
  description String?
  discord     String?
  telegram    String?
  youtube     String?
  donate      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
