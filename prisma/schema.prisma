generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model StreamerProfile {
  userLogin     String   @id
  description   String?
  discord       String?
  telegram      String?
  youtube       String?
  donate        String?
  thumbnailPath String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Tracks currently-live streams so the bot survives restarts without
/// sending duplicate "new stream" notifications.
model ActiveStream {
  id        String   @id        // Twitch stream ID
  userLogin String
  userName  String
  startedAt String             // ISO 8601 string from Twitch API
  seenAt    DateTime @default(now())
}

/// A Telegram channel/group linked to a specific Twitch streamer.
/// When that streamer goes live the bot posts a notification to that chat.
/// chatId is the primary key — one chat tracks exactly one streamer.
model ChannelSubscription {
  chatId        BigInt   @id
  streamerLogin String
  createdAt     DateTime @default(now())

  @@index([streamerLogin])
}

/// Personal subscriptions: a Telegram user subscribes to a Twitch streamer
/// and receives a DM when that streamer goes live.
model Subscription {
  id            Int      @id @default(autoincrement())
  userId        BigInt
  streamerLogin String
  createdAt     DateTime @default(now())

  @@unique([userId, streamerLogin])
  @@index([streamerLogin])
}
